[worldserver]

########################################
# mod-ollama-chat configuration
########################################

# --------------------------------------------
# CORE MODULE TOGGLES & DEBUGGING
# --------------------------------------------

# OllamaBotControl.Enable
#     Description: Enable or disable the module.
#     Default:     1 (true)
OllamaBotControl.Enable = 1

# OllamaBotControl.DebugEnabled
#     Description: Enables extra logging for debugging purposes.
#                  When set to 1 (true), detailed debug information will be logged by the module.
#                  When set to 0 (false), only standard logging is used.
#     Default:     0 (false)
OllamaBotControl.DebugEnabled = 0

# OllamaBotControl.DebugShowFullPrompt

#     Description: When enabled (1), logs the complete prompt sent to the Ollama API including RAG information.
#                  This is useful for debugging what information the RAG system provides to bots.
#                  Only active when OllamaBotControl.DebugEnabled is also enabled.
#                  When disabled (0), only standard logging is used.
#     Default:     0 (false)
OllamaBotControl.DebugShowFullPrompt = 0

# --------------------------------------------
# OLLAMA LLM CONNECTION AND INFERENCE
# --------------------------------------------

# OllamaBotControl.Url
#     Description: The URL used to query the Ollama API.
#     Default:     http://localhost:11434/api/generate
OllamaBotControl.Url = http://localhost:11434/api/generate

# OllamaBotControl.Model
#     Description: The model identifier to be used in the Ollama API request.
#     Default:     llama3.2:1b
OllamaBotControl.Model = llama3.2:1b

# OllamaBotControl.NumPredict
#     Description: Maximum number of tokens to generate in Ollama responses.
#     0 = unlimited. Only set if you want a hard cap.
#     Default: 40
#
#     | NumPredict | Approx. Words | Use Case                         |
#     |:----------:|:-------------:|:---------------------------------|
#     |     20     |   ~13–15      | Very short/emote/chat            |
#     |     30     |     ~20       | Short reply                      |
#     |     40     |   ~27–30      | Standard WoW reply (recommended) |
#     |     50     |   ~35–38      | Slightly longer reply            |
#     |     75     |   ~50–60      | Long quest/lore text             |
#     |    100+    |   70–80+      | Multi-paragraph (not typical)    |
OllamaBotControl.NumPredict = 100

# OllamaBotControl.Temperature
#     Description: Controls the "creativity" or randomness of the model’s output.
#                  Lower values (e.g., 0.2) = more focused, repetitive, and predictable.
#                  Higher values (e.g., 1.0) = more random, creative, or surprising.
#                  0.8 is the Ollama default.
#     Example:     OllamaBotControl.Temperature = 0.6
#     Default:     0.8
OllamaBotControl.Temperature = 0.8

# OllamaBotControl.TopP
#     Description: Controls nucleus sampling, another way to shape randomness.
#                  Lower values (e.g., 0.5) = more conservative.
#                  Higher values (up to 1.0) = more open.
#                  0.95 is the Ollama default.
#     Example:     OllamaBotControl.TopP = 0.9
#     Default:     0.95
OllamaBotControl.TopP = 0.95

# OllamaBotControl.RepeatPenalty
#     Description: Discourages repetition in model output.
#                  1.0 = no penalty. Higher (e.g., 1.2) = less repetition.
#                  1.1 is the Ollama default.
#     Example:     OllamaBotControl.RepeatPenalty = 1.2
#     Default:     1.1
OllamaBotControl.RepeatPenalty = 1.1

# OllamaBotControl.NumCtx
#     Description: Maximum context length (in tokens) sent to the model.
#                  0 = model default. Use a value only if you want to restrict or expand context.
#                  Example for Llama-3 8B: 8192. For 70B: 8192/32768.
#     Example:     OllamaBotControl.NumCtx = 4096
#     Default:     0
OllamaBotControl.NumCtx = 0

# OllamaBotControl.NumThreads
#     Description: Maximum number of threads the model should use to compute the request.
#                  0 = model default. Use a value only if you want to restrict or change from auto.
#                  
#     Example:     OllamaBotControl.NumThreads = 2
#     Default:     0
OllamaBotControl.NumThreads = 0

# OllamaBotControl.Stop
#     Description: Optional. Comma-separated list of string "stop sequences". If the model outputs any of these strings, it will immediately stop generating further text and return the response up to that point. Use this to prevent the model from continuing into unwanted sections, such as another user's dialogue turn in a chat application.
#                  Example: "User:,Bot:" will stop the output if "User:" or "Bot:" appears in the response. Leave blank to disable.
#     Example:     OllamaBotControl.Stop = User:,Bot:
#     Default:     (empty)
OllamaBotControl.Stop =

# OllamaBotControl.SystemPrompt
#     Description: Optional. Content for the "system" field sent to Ollama. Can be used to steer or "prime" the model's behavior globally.
#                  Leave blank for no system prompt, or enter your own.
#     Example:     OllamaBotControl.SystemPrompt = "Always answer as if you are a WoW quest giver."
#     Default:     (empty)
OllamaBotControl.SystemPrompt =

# OllamaBotControl.Seed
#     Description: Optional. Random seed for deterministic generation. Set to a number for repeatable results, or leave blank for normal random output.
#     Example:     OllamaBotControl.Seed = 42
#     Default:     (empty)
OllamaBotControl.Seed =

# OllamaBotControl.MaxConcurrentQueries
#     Description: The maximum number of concurrent API queries allowed. Use 0 for no limit.
#     Default:     0
OllamaBotControl.MaxConcurrentQueries = 0

# --------------------------------------------
# THINK MODE SUPPORT
# --------------------------------------------

# OllamaBotControl.ThinkModeEnableForModule
#     Description: Enables Think Mode for supported LLM models. When enabled, the API request will include the "think" flag,
#                  and only the main response will be returned, with all <think> tags and their contents stripped from bot replies.
#                  Make sure you set OllamaBotControl.NumPredict = 0 (unlimited) when using Think Mode.
#                  Certain models that require Think Mode must have this enabled to function properly.
#     Default:     0 (false)
OllamaBotControl.ThinkModeEnableForModule = 0

# --------------------------------------------
# GENERAL CHATTER / RESPONSE LOGIC
# --------------------------------------------

# OllamaBotControl.PlayerReplyChance.Say
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Say/Yell channels.
#     Default:     90
OllamaBotControl.PlayerReplyChance.Say = 90

# OllamaBotControl.BotReplyChance.Say
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Say/Yell channels.
#     Default:     10
OllamaBotControl.BotReplyChance.Say = 10

# OllamaBotControl.PlayerReplyChance.Channel
#     Description: The percent chance (0-100) that an eligible bot replies to a player in custom channels (General, Trade, etc.).
#     Default:     60
OllamaBotControl.PlayerReplyChance.Channel = 60

# OllamaBotControl.BotReplyChance.Channel
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in custom channels (General, Trade, etc.).
#     Default:     3
OllamaBotControl.BotReplyChance.Channel = 3

# OllamaBotControl.PlayerReplyChance.Party
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Party/Raid chat.
#     Default:     90
OllamaBotControl.PlayerReplyChance.Party = 90

# OllamaBotControl.BotReplyChance.Party
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Party/Raid chat.
#     Default:     25
OllamaBotControl.BotReplyChance.Party = 25

# OllamaBotControl.PlayerReplyChance.Guild
#     Description: The percent chance (0-100) that an eligible bot replies to a player in Guild/Officer chat.
#     Default:     70
OllamaBotControl.PlayerReplyChance.Guild = 70

# OllamaBotControl.BotReplyChance.Guild
#     Description: The percent chance (0-100) that an eligible bot replies to another bot in Guild/Officer chat.
#     Default:     5
OllamaBotControl.BotReplyChance.Guild = 5

# OllamaBotControl.EnableWhisperReplies
#     Description: Enable or disable bot responses to whisper messages.
#                  When set to 0 (false), bots will not reply to any whispers.
#                  When set to 1 (true), bots will reply to whispers based on normal reply chances.
#     Default:     0 (false)
OllamaBotControl.EnableWhisperReplies = 0

# OllamaBotControl.MaxBotsToPick
#     Description: The maximum number of bots that can be randomly selected to reply when no bot name is explicitly mentioned.
#     Default:     2
OllamaBotControl.MaxBotsToPick = 2

# OllamaBotControl.BlacklistCommands
#     Description: A comma-separated list of command prefixes that should be ignored by AI bots.
#                  If a message starts with any of these prefixes, the bot will not respond.
#     Default:     
OllamaBotControl.BlacklistCommands = autogear,talents,reset botAI,summon,release,revive,leave,attack,follow,flee,stay,runaway,grind,disperse,give leader,spells,cast ,quests,accept,drop,talk,reset,ss ,trainer,rti,rtsc,do ,ll ,e ,ue ,nc ,open,destroy,s ,b ,bank,gb ,u ,co ,ELVUI_VERSIONCHK,Asked,DPSMate_,LibGroupTalents,BLT,oRA3,Skada,HealBot,hbComms,questie,pfQuest,DBMv4-Ver,BWVQ3,add,remove,reset ai,report,state,help,log,stats,tank,offtank,healer,cc ,damage,boost,passive,defensive,aggressive,stay,guard,free,follow,assist,pet,stance,formation,rpg,emote,cheer,applaud,drink,eat,dance,attackers,reset instances,home,zone,who ,pos ,tele,grind,loot,quest,trainer,travel,teleport,homebind,unfollow,invite,uninvite,join,leave,leader,ready,release,save,update,reset talents,gear,trade,mail,ah ,ahscan,ahbid,ahbuy,ahsell,ahcancel,bag,repair,vendor,train,spells,reset spells,learn,unlearn,cast,uncast,use ,move,go ,look,stop,turn,face,wait,party,followleader,stayleader,moveleader,info,distance,debug,reset path,reset state,reset all,reset dungeon,reset raid,zone info,LHC40,RECOUNT,GTFO_v,Altoholic,DS_,DataStore

# OllamaBotControl.SayDistance
#     Description: The maximum distance (in game units) a bot must be within to reply on a Say message.
#     Default:     30.0
OllamaBotControl.SayDistance = 30.0

# OllamaBotControl.YellDistance
#     Description: The maximum distance (in game units) a bot must be within to reply on a Yell message.
#     Default:     100.0
OllamaBotControl.YellDistance = 100.0

# OllamaBotControl.DisableForCustomChannels
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in custom channels (General, Trade, LookingForGroup, etc.).
#                  This allows you to reduce spam in public channels while keeping bot interactions in other chat types.
#     Default:     0 (false)
OllamaBotControl.DisableForCustomChannels = 0

# OllamaBotControl.DisableForSayYell
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Say and Yell channels.
#                  Useful if you want bots to be silent in proximity-based chats.
#     Default:     0 (false)
OllamaBotControl.DisableForSayYell = 0

# OllamaBotControl.DisableForGuild
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Guild and Officer channels.
#                  Useful for keeping guild chat focused without bot chatter.
#     Default:     0 (false)
OllamaBotControl.DisableForGuild = 0

# OllamaBotControl.DisableForParty
#     Description: When enabled (1), disables Ollama bot replies, random chatter, and events in Party and Raid channels.
#                  Useful if you want party chat to be bot-free.
#     Default:     0 (false)
OllamaBotControl.DisableForParty = 0

# --------------------------------------------
# RANDOM CHATTER SYSTEM
# --------------------------------------------

# OllamaBotControl.EnableRandomChatter
#     Description: Enable or disable random chatter from AI bots when a real player is nearby.
#     Default:     1 (true)
OllamaBotControl.EnableRandomChatter = 1

# OllamaBotControl.DisableRepliesInCombat
#     Description: If true, bots will not reply or produce random chatter when in combat.
#     Default:     1
OllamaBotControl.DisableRepliesInCombat = 1

# OllamaBotControl.MinRandomInterval
#     Description: The minimum time (in seconds) between random lines from an AI bot.
#     Default:     45
OllamaBotControl.MinRandomInterval = 45

# OllamaBotControl.MaxRandomInterval
#     Description: The maximum time (in seconds) between random lines from an AI bot.
#     Default:     180
OllamaBotControl.MaxRandomInterval = 180

# OllamaBotControl.RandomChatterRealPlayerDistance
#     Description: The maximum distance (in game units) a real player must be within for random bot chatter to trigger.
#     Default:     200.0
OllamaBotControl.RandomChatterRealPlayerDistance = 200.0

# OllamaBotControl.RandomChatterBotCommentChance
#     Description: The percent chance (0-100) that an AI bot will add a comment when random chatter is triggered.
#     Default:     5
OllamaBotControl.RandomChatterBotCommentChance = 5

# OllamaBotControl.RandomChatterMaxBotsPerPlayer
#     Description: The maximum number of AI bots that can trigger per random chatter update when a real player is nearby.
#                  This limits how many bots can respond at once to avoid spam.
#                   Each bot can only process once per tick, no duplicates if multiple real players are close.
#     Default:     2
OllamaBotControl.RandomChatterMaxBotsPerPlayer = 2

# OllamaBotControl.RandomChatterPromptTemplate
#   Description: The template string for random bot chatter prompts.
#   Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_area} {bot_zone} {bot_map} {bot_personality} {bot_personality_name} {environment_info}
#   Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
OllamaBotControl.RandomChatterPromptTemplate = "You are a Wrath-era WoW player. Name: {bot_name}, Level: {bot_level} {bot_class}, {bot_race} {bot_gender}, Spec: {bot_role}, Faction: {bot_faction}. Location: {bot_area}, Zone: {bot_zone}, Map: {bot_map}. MAKE SURE YOU RESPOND USING YOUR PERSONALITY, WHICH IS: {bot_personality_name}: {bot_personality}. {environment_info} Reply casually in under 15 words. No quotes, markdown, symbols, or emojis. Use real WoW slang. Avoid uncommon jargon or formatting."

# OllamaBotControl.RandomChatterPromptVariations
#   Description: Pipe-separated (|) list of additional prompt instructions that will be randomly selected and appended to the RandomChatterPromptTemplate.
#                This adds variety to bot responses by changing the angle or focus of their random chatter.
#                One variation is randomly chosen each time a bot generates random chatter.
#                Leave empty to disable variations and use only the base template.
#   Example:     "Talk about the weather or environment.|Comment on your current task or goal.|Make an observation about nearby creatures or players."
#   Default:     (see below for Wrath-era appropriate variations)
OllamaBotControl.RandomChatterPromptVariations = "Complain about something typical WoW players complain about.|Make a casual observation about leveling or grinding.|Share your opinion on Horde vs Alliance.|Comment on how tough or easy the zone feels.|Make a joke or sarcastic remark about WoW.|Mention something about the Lich King expansion.|Talk about wanting better gear or loot.|Comment on flying mounts or Northrend travel.|Complain about repair costs or gold.|Make an observation about your class in general.|Comment on dungeon finder or group content.|Talk about daily quests or reputation grinds.|Mention Death Knights being OP or annoying.|Share your thoughts on arena or battlegrounds.|Complain about nerfed abilities or changes.|Talk about needing to farm materials or gold.|Comment on the cold weather in Northrend.|Mention wanting to raid or do heroics.|Talk about achievements being too grindy.|Make a casual remark about quest objectives."

# OllamaBotControl.RandomChatterQuestionVariations
#   Description: Pipe-separated (|) list of prompt instructions telling the LLM to generate questions that will stimulate OTHER bots or players to respond.
#                When a bot uses one of these variations, the LLM will generate a question based on the prompt instruction.
#                These questions are meant to encourage other bots (via BotReplyChance) and real players to engage in conversation.
#                When a bot generates random chatter, it will randomly choose between making a statement (RandomChatterPromptVariations)
#                or asking a question (RandomChatterQuestionVariations).
#                Leave empty to disable question variations and only use statement variations.
#   Example:     "Ask about dungeon preferences.|Ask if anyone wants to PvP.|Ask about raid progression."
#   Default:     (see below for engaging Wrath-era question prompts designed to stimulate bot-to-bot and player-to-bot conversations)
OllamaBotControl.RandomChatterQuestionVariations = "Ask if others think this zone is difficult.|Ask about favorite dungeons.|Ask about Icecrown Citadel progression.|Ask about daily quest frustrations.|Ask about Naxxramas difficulty compared to original.|Ask what spec people are running.|Ask about Death Knight popularity.|Ask about upcoming Death Knight nerfs.|Ask about gold-making strategies in Wrath.|Ask if anyone is farming badges.|Ask about excitement for Ulduar.|Ask if dual spec was worth the cost.|Ask about opinions on the old talent trees.|Ask about favorite raid bosses.|Ask if flying mounts ruined world PvP.|Ask who's doing arena this season.|Ask about arena ratings.|Ask about Wintergrasp balance.|Ask about Oculus dungeon opinions.|Ask which professions make the most gold.|Ask about old-world flying possibilities.|Ask about reputation mount farming.|Ask which heroic dungeon is hardest.|Ask if emblems are too easy to get."

# --------------------------------------------
# EVENT CHATTER SYSTEM
# --------------------------------------------

# OllamaBotControl.EnableEventChatter
#     Description: Enables or disables the event-based chatter system (e.g. player deaths, entering zones).
#                  When enabled (1), bots will respond to predefined game events.
#     Default:     1 (true)
OllamaBotControl.EnableEventChatter = 1

# OllamaBotControl.EventChatterRealPlayerDistance
#     Description: The maximum distance (in game units) a real player must be within to trigger event-based bot chatter.
#     Default:     40.0
OllamaBotControl.EventChatterRealPlayerDistance = 40.0

# OllamaBotControl.EventChatterBotCommentChance
#     Description: The percent chance (0–100) that an AI bot will respond to a game event another player generates.
#     Default:     25
OllamaBotControl.EventChatterBotCommentChance = 25

# OllamaBotControl.EventChatterBotSelfCommentChance
#     Description: The percent chance (0–100) that an AI bot will respond to a game event it generates itself.
#     Default:     5
OllamaBotControl.EventChatterBotSelfCommentChance = 5

# OllamaBotControl.EventChatterMaxBotsPerPlayer
#     Description: The maximum number of bots allowed to respond to a single player's event.
#     Default:     2
OllamaBotControl.EventChatterMaxBotsPerPlayer = 2

# OllamaBotControl.EventChatterPromptTemplate
#     Description: The template used to generate bot prompts when reacting to world events.

#     Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_area} {bot_zone} {bot_map} {bot_personality} {bot_personality_name} {event_type} {event_detail} {actor_name} {sentiment_info}
#     Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
OllamaBotControl.EventChatterPromptTemplate = "You are {bot_name}, a level {bot_level} {bot_class} ({bot_race} {bot_gender}) specializing as a {bot_role} from the {bot_faction} faction. You are currently in {bot_area}, Zone: {bot_zone}, Map: {bot_map}. Personality: {bot_personality_name}: {bot_personality}. {sentiment_info} Event: {actor_name} {event_type} {event_detail}. Respond to this specific Event that just happened in character, casually, in under 15 words. Avoid emojis, markdown, or narration."

# --------------------------------------------
# TYPING SIMULATION
# --------------------------------------------

# OllamaBotControl.EnableTypingSimulation
#     Description: When enabled (1), bots will delay their responses proportionally to the message length
#                  to simulate realistic typing behavior. The delay is calculated as:
#                  BaseDelay + (MessageLength * DelayPerChar) milliseconds
#                  Example: 100 character message with defaults = 1000ms + (100 * 250ms) = 26 seconds
#     Default:     0 (false)
OllamaBotControl.EnableTypingSimulation = 0

# OllamaBotControl.TypingSimulationBaseDelay
#     Description: Base delay in milliseconds before a bot starts "typing" a response.
#                  This simulates the time it takes to read the message and start typing.
#     Default:     1000
OllamaBotControl.TypingSimulationBaseDelay = 1000

# OllamaBotControl.TypingSimulationDelayPerChar
#     Description: Additional delay in milliseconds per character in the bot's response.
#                  Realistic typing speeds:
#                  - 400ms per char = 2.5 chars/sec (slow/casual)
#                  - 250ms per char = 4 chars/sec (average human)
#                  - 150ms per char = 6.7 chars/sec (proficient)
#                  - 100ms per char = 10 chars/sec (professional)
#     Default:     250
OllamaBotControl.TypingSimulationDelayPerChar = 250

# --------------------------------------------
# RP PERSONALITIES SYSTEM
# --------------------------------------------

# OllamaBotControl.EnableRPPersonalities
#     Description: Enables or disables the use of defined roleplay personalities for AI bots.
#                  When enabled (1), bots will respond with distinct personalities based on their assigned type.
#                  When disabled (0), bots will use a neutral/default response style.
#     Default:     0 (false)
OllamaBotControl.EnableRPPersonalities = 0

# OllamaBotControl.DefaultPersonalityPrompt
#     Description: The fallback personality description used when a bot has no specific roleplay type assigned.
#     Default:     Talk like a standard WoW player.
OllamaBotControl.DefaultPersonalityPrompt = "Speak like a real WoW player from Wrath. Stay in character and use casual in-game tone."

# --------------------------------------------
# CONVERSATION HISTORY AND SNAPSHOT SYSTEM
# --------------------------------------------

# OllamaBotControl.EnableChatHistory
#     Description: Enables or disables the use of Chat History.
#     Default:     1 (true)
OllamaBotControl.EnableChatHistory = 1

# OllamaBotControl.MaxConversationHistory
#     Description: The maximum number of recent message pairs (player + bot reply) to track per bot/player combination.
#                  This history is stored in memory and included in the LLM prompt when the same player talks to the bot again.
#     Default:     5
OllamaBotControl.MaxConversationHistory = 5

# OllamaBotControl.ConversationHistorySaveInterval
#     Description: The interval (in minutes) between periodic saves of conversation history from memory to the database.
#                  Set to 0 to disable auto-saving.
#     Default:     10
OllamaBotControl.ConversationHistorySaveInterval = 10

# OllamaBotControl.EnableChatBotSnapshotTemplate
#     Description: Enable or disable additional awareness context for each bot.
#                  When enabled (1), the bot will include a snapshot of its current status and surroundings in the chat prompt.
#                  This includes combat status, group info, known spells, active quests, line of sight objects, and nearby players.
#                  When disabled (0), this context is not included in the chat prompt.
#                  This is useful for bots that need to be aware of their environment and current status.
#                  Enabling this may increase the response time and token usage of the API calls.
#     Default:     0 (false)
OllamaBotControl.EnableChatBotSnapshotTemplate = 0

# OllamaBotControl.ChatHistoryHeaderTemplate
#   Description: Format for header in conversation history context.
#   Placeholders (named): {player_name}
OllamaBotControl.ChatHistoryHeaderTemplate = "Recent chats with {player_name}. Use only for context. Reply to the new message."

# OllamaBotControl.ChatHistoryLineTemplate
#   Description: Format for each line in conversation history context.
#   Placeholders (named): {player_name} {player_message} {bot_reply}
OllamaBotControl.ChatHistoryLineTemplate = "{player_name} said: {player_message}\nYou said: {bot_reply}\n"

# OllamaBotControl.ChatHistoryFooterTemplate
#   Description: Format for footer in conversation history context.
#   Placeholders (named): {player_name} {player_message}
OllamaBotControl.ChatHistoryFooterTemplate = "NEW MESSAGE from {player_name}: {player_message}"

# OllamaBotControl.ChatBotSnapshotTemplate
#   Description: The template string for the context snapshot of the bot's surroundings and status.
#   Placeholders (named): {combat} {group} {spells} {quests} {los} {players}
OllamaBotControl.ChatBotSnapshotTemplate = "CURRENT CONTEXT:\n{combat}\n{group}\nSpells:\n{spells}\nQuests:\n{quests}\nVisible Objects:\n{los}\nNearby Players:\n{players}"

# ----------------------------------------------
# SENTIMENT TRACKING SYSTEM
# ----------------------------------------------

# Enable or disable sentiment tracking between bots and players
# Disabled by default due to needing an extra LLM call.
# Default: 0 (disabled)
OllamaBotControl.EnableSentimentTracking = 0

# Default sentiment value for new bot-player relationships
# Range: 0.0 (hostile) to 1.0 (friendly), 0.5 = neutral
# Default: 0.5
OllamaBotControl.SentimentDefaultValue = 0.5

# How much to adjust sentiment per positive/negative message
# Range: 0.01 to 0.5 (smaller = more gradual changes)
# Default: 0.05
OllamaBotControl.SentimentAdjustmentStrength = 0.05

# How often to save sentiment data to database (in minutes)
# Set to 0 to disable periodic saving
# Default: 10
OllamaBotControl.SentimentSaveInterval = 10

# Prompt template for sentiment analysis
# Use {message} placeholder for the message to analyze
# Default: "Analyze the sentiment of this message: \"{message}\". Respond only with: POSITIVE, NEGATIVE, or NEUTRAL."
OllamaBotControl.SentimentAnalysisPrompt = "Analyze the sentiment of this message: \"{message}\". Respond only with: POSITIVE, NEGATIVE, or NEUTRAL."

# Template for including sentiment information in bot prompts
# Use {player_name} and {sentiment_value} placeholders
# Default: "Your relationship sentiment with {player_name} is {sentiment_value} (0.0=hostile, 0.5=neutral, 1.0=friendly). Use this to guide your tone and response."
OllamaBotControl.SentimentPromptTemplate = "Your relationship sentiment with {player_name} is {sentiment_value} (0.0=hostile, 0.5=neutral, 1.0=friendly). Use this to guide your tone and response."

# --------------------------------------------
# CHAT/PROMPT TEMPLATES
# --------------------------------------------

# OllamaBotControl.ChatPromptTemplate
#   Description: The main template for bot chat prompts sent to the LLM.
#   Placeholders (named): {bot_name} {bot_level} {bot_class} {bot_personality} {bot_personality_name} {player_level} {player_class} {player_name} {player_message} {extra_info} {sentiment_info}
#   Note: {bot_personality_name} contains the name/key of the personality (e.g., "grumpy", "helpful"), while {bot_personality} contains the full personality description text.
OllamaBotControl.ChatPromptTemplate = "You're a Wrath-era WoW player familiar with Vanilla and TBC. Name: {bot_name}, Level: {bot_level} {bot_class}, MAKE SURE YOU RESPOND USING YOUR PERSONALITY, WHICH IS: {bot_personality_name}: {bot_personality}. {sentiment_info} {chat_history} A level {player_level} {player_class} named {player_name} said: '{player_message}'. {extra_info} Reply naturally in under 15 words. Use authentic WoW tone. Be blunt if provoked. Be precise if giving directions. Never contradict your class, race, or location. Never act like a narrator—just respond like a player."

# OllamaBotControl.ChatExtraInfoTemplate
#   Description: The context/details string about the bot and player, injected into the chat prompt as the last parameter.
#   Placeholders (named): {bot_race} {bot_gender} {bot_role} {bot_faction} {bot_guild} {bot_group_status} {bot_gold} {player_race} {player_gender} {player_role} {player_faction} {player_guild} {player_group_status} {player_gold} {player_distance} {bot_area} {bot_zone} {bot_map}
OllamaBotControl.ChatExtraInfoTemplate = "Your Info: {bot_race} {bot_gender}, Spec: {bot_role}, Faction: {bot_faction}, Guild: {bot_guild}, Group: {bot_group_status}, Gold: {bot_gold}. Player Info: {player_race} {player_gender}, Spec: {player_role}, Faction: {player_faction}, Guild: {player_guild}, Group: {player_group_status}, Gold: {player_gold}, Distance: {player_distance} yards. Location: {bot_area}, Zone: {bot_zone}, Map: {bot_map}. Only respond to the new message. No commentary, no meta-talk, no prefix—just the reply."

# --------------------------------------------
# ENVIRONMENTAL/CONTEXTUAL TEMPLATES
# --------------------------------------------

# OllamaBotControl.EnvCommentCreature
#   Description: A pipe-separated (|) list of template messages for when any creature is spotted nearby.
#   Placeholders (named): {creature_name}
OllamaBotControl.EnvCommentCreature = You spot a creature named '{creature_name}' and react cautiously.|You spot a creature named '{creature_name}' and assess its threat.|You spot a creature named '{creature_name}' and comment on its behavior.|You spot a creature named '{creature_name}' and consider whether to engage.|You spot a creature named '{creature_name}' and recall what you know about it.|You spot a creature named '{creature_name}' and comment on its appearance.|You spot a creature named '{creature_name}' and decide if it should be avoided.|You spot a creature named '{creature_name}' and speculate on its intentions.

# OllamaBotControl.EnvCommentGameObject
#   Description: A pipe-separated (|) list of template messages for when a game object is nearby.
#   Placeholders (named): {object_name}
OllamaBotControl.EnvCommentGameObject = You see {object_name} nearby and comment on its purpose.|You see {object_name} nearby and decide whether to interact.|You see {object_name} nearby and recall why it is useful.|You see {object_name} nearby and judge its condition.|You see {object_name} nearby and consider if it is valuable.|You see {object_name} nearby and explain what it might be used for.|You see {object_name} nearby and react with curiosity.|You see {object_name} nearby and decide whether to investigate.

# OllamaBotControl.EnvCommentEquippedItem
#   Description: A pipe-separated (|) list of template messages referencing a random equipped item.
#   Placeholders (named): {item_name}
OllamaBotControl.EnvCommentEquippedItem = Talk about your equipped item {item_name} and why you chose it.|Talk about your equipped item {item_name} and how it helps you.|Talk about your equipped item {item_name} and its strengths.|Talk about your equipped item {item_name} and any weaknesses.|Talk about your equipped item {item_name} and how it feels to use.|Talk about your equipped item {item_name} and when it is most effective.|Talk about your equipped item {item_name} and compare it to alternatives.|Talk about your equipped item {item_name} and your confidence in it.

# OllamaBotControl.EnvCommentBagItem
#   Description: A pipe-separated (|) list of template messages for an item in the bot's bag.
#   Placeholders (named): {item_name}
OllamaBotControl.EnvCommentBagItem = You notice a {item_name} in your bag and consider using it.|You notice a {item_name} in your bag and explain why you keep it.|You notice a {item_name} in your bag and decide if it is still useful.|You notice a {item_name} in your bag and recall where you got it.|You notice a {item_name} in your bag and judge its value.|You notice a {item_name} in your bag and think about trading it.|You notice a {item_name} in your bag and plan when to use it.|You notice a {item_name} in your bag and comment on its condition.

# OllamaBotControl.EnvCommentBagItemSell
#   Description: A pipe-separated (|) list of template messages for an item the bot might try to sell.
#   Placeholders (named): {item_count} {item_name}
OllamaBotControl.EnvCommentBagItemSell = You are trying persuasively to sell {item_count} of this item {item_name} by highlighting its benefits.|You are trying persuasively to sell {item_count} of this item {item_name} by stressing its rarity.|You are trying persuasively to sell {item_count} of this item {item_name} by appealing to need.|You are trying persuasively to sell {item_count} of this item {item_name} by offering a deal.|You are trying persuasively to sell {item_count} of this item {item_name} by explaining its uses.|You are trying persuasively to sell {item_count} of this item {item_name} by comparing it to others.|You are trying persuasively to sell {item_count} of this item {item_name} by creating urgency.|You are trying persuasively to sell {item_count} of this item {item_name} by praising its quality.

# OllamaBotControl.EnvCommentSpell
#   Description: A pipe-separated (|) list of template messages about a random known spell.
#   Placeholders (named): {spell_name} {spell_effect} {spell_cost}
OllamaBotControl.EnvCommentSpell = Discuss possible uses or strategies for '{spell_name}' in the current situation.|Discuss possible uses or strategies for '{spell_name}' against different enemies.|Discuss possible uses or strategies for '{spell_name}' when resources are low.|Discuss possible uses or strategies for '{spell_name}' and its risks.|Discuss possible uses or strategies for '{spell_name}' compared to other spells.|Discuss possible uses or strategies for '{spell_name}' in group combat.|Discuss possible uses or strategies for '{spell_name}' outside of combat.|Discuss possible uses or strategies for '{spell_name}' given its cost of {spell_cost}.

# OllamaBotControl.EnvCommentQuestArea
#   Description: A pipe-separated (|) list of template messages to suggest an area to quest in.
#   Placeholders (named): {quest_area}
OllamaBotControl.EnvCommentQuestArea = Suggest you could go questing around {quest_area} and explain why.|Suggest you could go questing around {quest_area} based on your level.|Suggest you could go questing around {quest_area} for rewards.|Suggest you could go questing around {quest_area} due to recent rumors.|Suggest you could go questing around {quest_area} to gain experience.|Suggest you could go questing around {quest_area} and note the dangers.|Suggest you could go questing around {quest_area} if prepared.|Suggest you could go questing around {quest_area} and set a goal.

# OllamaBotControl.EnvCommentVendor
#   Description: A pipe-separated (|) list of template messages when a vendor NPC is nearby.
#   Placeholders (named): {vendor_name}
OllamaBotControl.EnvCommentVendor = You spot {vendor_name} selling wares nearby and consider browsing.|You spot {vendor_name} selling wares nearby and recall past deals.|You spot {vendor_name} selling wares nearby and check your coin.|You spot {vendor_name} selling wares nearby and judge their stock.|You spot {vendor_name} selling wares nearby and decide whether to trade.|You spot {vendor_name} selling wares nearby and comment on their reputation.|You spot {vendor_name} selling wares nearby and look for upgrades.|You spot {vendor_name} selling wares nearby and compare prices.

# OllamaBotControl.EnvCommentQuestgiver
#   Description: A pipe-separated (|) list of template messages when a questgiver NPC is nearby.
#   Placeholders (named): {questgiver_name} {quest_count}
OllamaBotControl.EnvCommentQuestgiver = {questgiver_name} looks like they have {quest_count} quests and you evaluate which to take.|{questgiver_name} looks like they have {quest_count} quests and you judge the risk.|{questgiver_name} looks like they have {quest_count} quests and you consider rewards.|{questgiver_name} looks like they have {quest_count} quests and you recall past work.|{questgiver_name} looks like they have {quest_count} quests and you assess urgency.|{questgiver_name} looks like they have {quest_count} quests and you choose carefully.|{questgiver_name} looks like they have {quest_count} quests and you plan next steps.|{questgiver_name} looks like they have {quest_count} quests and you comment on their tone.

# OllamaBotControl.EnvCommentBagSlots
#   Description: A pipe-separated (|) list of template messages about available bag slots.
#   Placeholders (named): {bag_slots}
OllamaBotControl.EnvCommentBagSlots = You have {bag_slots} free bag slots left and decide how cautious to be.|You have {bag_slots} free bag slots left and plan your looting.|You have {bag_slots} free bag slots left and consider selling items.|You have {bag_slots} free bag slots left and comment on inventory pressure.|You have {bag_slots} free bag slots left and adjust priorities.|You have {bag_slots} free bag slots left and plan ahead.|You have {bag_slots} free bag slots left and evaluate risk.|You have {bag_slots} free bag slots left and think about storage.

# OllamaBotControl.EnvCommentDungeon
#   Description: A pipe-separated (|) list of template messages for when the bot is in a dungeon.
#   Placeholders (named): {dungeon_name}
OllamaBotControl.EnvCommentDungeon = You're in a Dungeon instance named '{dungeon_name}' and comment on the atmosphere.|You're in a Dungeon instance named '{dungeon_name}' and recall known bosses.|You're in a Dungeon instance named '{dungeon_name}' and plan your approach.|You're in a Dungeon instance named '{dungeon_name}' and assess danger.|You're in a Dungeon instance named '{dungeon_name}' and prepare mentally.|You're in a Dungeon instance named '{dungeon_name}' and comment on layout.|You're in a Dungeon instance named '{dungeon_name}' and recall past runs.|You're in a Dungeon instance named '{dungeon_name}' and set expectations.

# OllamaBotControl.EnvCommentUnfinishedQuest
#   Description: A pipe-separated (|) list of template messages about a random incomplete quest in the bot's log.
#   Placeholders (named): {quest_name}
OllamaBotControl.EnvCommentUnfinishedQuest = Say the name of and talk about your un-finished quest '{quest_name}' and what remains.|Say the name of and talk about your un-finished quest '{quest_name}' and its difficulty.|Say the name of and talk about your un-finished quest '{quest_name}' and why it stalled.|Say the name of and talk about your un-finished quest '{quest_name}' and your next step.|Say the name of and talk about your un-finished quest '{quest_name}' and its rewards.|Say the name of and talk about your un-finished quest '{quest_name}' and the risks.|Say the name of and talk about your un-finished quest '{quest_name}' and your motivation.|Say the name of and talk about your un-finished quest '{quest_name}' and its urgency.

# --------------------------------------------
# EVENT TEMPLATES
