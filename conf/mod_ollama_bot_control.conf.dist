# OllamaBotControl.EventTypeDefeated
#     Description: The event type string for when a player or bot defeats a creature.
#     Used in: Event-based chat prompts. Example: "Kurim defeated Hogger."
#     Default:     defeated
OllamaBotControl.EventTypeDefeated = defeated
OllamaBotControl.EventTypeDefeated_Chance = 1

# OllamaBotControl.EventTypeDefeatedPlayer
#     Description: The event type string for when a player defeats another player (PvP kill).
#     Used in: Event-based chat prompts for PvP kills.
#     Default:     defeated player
OllamaBotControl.EventTypeDefeatedPlayer = defeated player
OllamaBotControl.EventTypeDefeatedPlayer_Chance = 10

# OllamaBotControl.EventTypePetDefeated
#     Description: The event type string for when a player's pet defeats a creature.
#     Used in: Event-based chat prompts.
#     Default:     pet defeated
OllamaBotControl.EventTypePetDefeated = pet defeated
OllamaBotControl.EventTypePetDefeated_Chance = 2

# OllamaBotControl.EventTypeGotItem
#     Description: The event type string for when a player obtains a rare or higher quality item.
#     Used in: Event-based chat when a player gets a notable item.
#     Default:     got item
OllamaBotControl.EventTypeGotItem = got item
OllamaBotControl.EventTypeGotItem_Chance = 65

# OllamaBotControl.EventTypeDied
#     Description: The event type string for when a player dies.
#     Used in: Event-based chat when a player death occurs.
#     Default:     died
OllamaBotControl.EventTypeDied = died
OllamaBotControl.EventTypeDied_Chance = 18

# OllamaBotControl.EventTypeCompletedQuest
#     Description: The event type string for when a player completes a quest.
#     Used in: Event-based chat when a quest is completed.
#     Default:     completed quest
OllamaBotControl.EventTypeCompletedQuest = completed quest
OllamaBotControl.EventTypeCompletedQuest_Chance = 35

# OllamaBotControl.EventTypeLearnedSpell
#     Description: The event type string for when a player learns a new spell.
#     Used in: Event-based chat for spell learning.
#     Default:     learned spell
OllamaBotControl.EventTypeLearnedSpell = learned spell
OllamaBotControl.EventTypeLearnedSpell_Chance = 2

# OllamaBotControl.EventTypeRequestedDuel
#     Description: The event type string for when a player requests a duel.
#     Used in: Event-based chat on duel request.
#     Default:     requested to duel
OllamaBotControl.EventTypeRequestedDuel = requested to duel
OllamaBotControl.EventTypeRequestedDuel_Chance = 28

# OllamaBotControl.EventTypeStartedDueling
#     Description: The event type string for when a duel starts between players.
#     Used in: Event-based chat when a duel begins.
#     Default:     started dueling
OllamaBotControl.EventTypeStartedDueling = started dueling
OllamaBotControl.EventTypeStartedDueling_Chance = 10

# OllamaBotControl.EventTypeWonDuel
#     Description: The event type string for when a player wins a duel.
#     Used in: Event-based chat for duel win.
#     Default:     won duel against
OllamaBotControl.EventTypeWonDuel = won duel against
OllamaBotControl.EventTypeWonDuel_Chance = 85

# OllamaBotControl.EventTypeLeveledUp
#     Description: The event type string for when a player levels up.
#     Used in: Event-based chat on level up.
#     Default:     leveled up
OllamaBotControl.EventTypeLeveledUp = leveled up
OllamaBotControl.EventTypeLeveledUp_Chance = 75

# OllamaBotControl.EventTypeAchievement
#     Description: The event type string for when a player earns an achievement.
#     Used in: Event-based chat for achievements.
#     Default:     earned achievement
OllamaBotControl.EventTypeAchievement = earned achievement
OllamaBotControl.EventTypeAchievement_Chance = 75

# OllamaBotControl.EventTypeUsedObject
#     Description: The event type string for when a player uses a game object.
#     Used in: Event-based chat when using objects in the world.
#     Default:     used object
OllamaBotControl.EventTypeUsedObject = used object
OllamaBotControl.EventTypeUsedObject_Chance = 10

# OllamaBotControl.EventCooldownTime
#     Description: The cooldown time (in seconds) for bots to respond to an event.
#     Default:     10
OllamaBotControl.EventCooldownTime = 10

# --------------------------------------------
# GUILD-SPECIFIC RANDOM CHATTER
# --------------------------------------------

# OllamaBotControl.EnableGuildRandomAmbientChatter
#     Description: Enable or disable random ambient guild chatter from bots in guilds with real players online.
#     Default:     1 (true)
OllamaBotControl.EnableGuildRandomAmbientChatter = 1

# OllamaBotControl.GuildRandomChatterChance
#     Description: Percent chance (0-100) for a bot to send a random guild chat message when eligible.
#     Default:     10
OllamaBotControl.GuildRandomChatterChance = 85

# OllamaBotControl.EnableGuildEventChatter
#     Description: Enable guild-specific random chatter for bots in guilds with real players.
#                  When enabled, bots will make guild-related comments and use guild chat.
#                  Only activates when real players are online in the same guild as the bot.
#     Default: 1 (true)
OllamaBotControl.EnableGuildEventChatter = 1

# OllamaBotControl.GuildChatterBotCommentChance
#     Description: Percentage chance (0-100) for guild bots to comment on guild events.
#                  This applies to events like level ups, gear acquisition, dungeon completion.
#                  Lower values = less frequent guild event responses.
#     Default: 65
OllamaBotControl.GuildChatterBotCommentChance = 65

# OllamaBotControl.GuildChatterMaxBotsPerEvent
#     Description: Maximum number of guild bots that can respond to a single guild event.
#                  Prevents spam when multiple guild bots want to comment on the same event.
#                  Example: If set to 2, only 2 bots max will respond to a member leveling up.
#     Default: 2
OllamaBotControl.GuildChatterMaxBotsPerEvent = 2

# --------------------------------------------
# GUILD ENVIRONMENT COMMENT TEMPLATES
# --------------------------------------------

# OllamaBotControl.GuildEnvCommentGuildMember
#     Description: Templates for commenting on guild members. Pipe-separated (|) list.
#     Placeholders: {member_name}
#     Example: "I wonder what {member_name} is up to today."
#     Default: (empty - no guild member comments)
OllamaBotControl.GuildEnvCommentGuildMember = I wonder what {member_name} is up to today.|{member_name} is a solid guild member.|Haven't seen {member_name} around much lately.

# OllamaBotControl.GuildEnvCommentGuildRank
#     Description: Templates for commenting on guild ranks. Pipe-separated (|) list.
#     Placeholders: {guild_rank}
#     Example: "Being a {guild_rank} has its perks."
#     Default: (empty - no guild rank comments)
OllamaBotControl.GuildEnvCommentGuildRank = Being a {guild_rank} has its perks.|The {guild_rank} rank comes with responsibilities.|I'm proud to be a {guild_rank} in this guild.

# OllamaBotControl.GuildEnvCommentGuildBank
#     Description: Templates for commenting on guild bank status. Pipe-separated (|) list.
#     Placeholders: {bank_gold}
#     Example: "Guild bank has {bank_gold} gold saved up."
#     Default: (empty - no guild bank comments)
OllamaBotControl.GuildEnvCommentGuildBank = Guild bank has {bank_gold} gold saved up.|We should check what's in the guild bank.|{bank_gold} gold in the guild bank, not bad.|The guild bank could use some donations.

# OllamaBotControl.GuildEnvCommentGuildMOTD
#     Description: Templates for commenting on guild message of the day. Pipe-separated (|) list.
#     Placeholders: {guild_motd}
#     Example: "Guild MOTD says: {guild_motd}"
#     Default: (empty - no guild MOTD comments)
OllamaBotControl.GuildEnvCommentGuildMOTD = Guild MOTD says: {guild_motd}|Did everyone see the guild message? {guild_motd}|The officers updated the MOTD: {guild_motd}

# OllamaBotControl.GuildEnvCommentGuildInfo
#     Description: Templates for commenting on guild information. Pipe-separated (|) list.
#     Placeholders: {guild_info}
#     Example: "Our guild info reads: {guild_info}"
#     Default: (empty - no guild info comments)
OllamaBotControl.GuildEnvCommentGuildInfo = Our guild info reads: {guild_info}|Check out the guild info if you haven't: {guild_info}|The guild description says it all: {guild_info}

# OllamaBotControl.GuildEnvCommentGuildOnlineMembers
#     Description: Templates for commenting on online guild members. Pipe-separated (|) list.
#     Placeholders: {online_count}, {total_count}
#     Example: "We have {online_count} out of {total_count} guild members online."
#     Default: (empty - no online member comments)
OllamaBotControl.GuildEnvCommentGuildOnlineMembers = We have {online_count} out of {total_count} guild members online.|{online_count} guildies are online right now.|Nice to see {online_count} guild members active today.|Only {online_count} of us online from the guild.

# --------------------------------------------
# GUILD RANDOM CHATTER PROMPTS
# --------------------------------------------

# OllamaBotControl.GuildEnvCommentGuildRaid
#     Description: Templates for commenting on guild raid activity. Pipe-separated (|) list.
#     Example: "Looking forward to the next guild raid!"
#     Default: (empty - no raid comments)
OllamaBotControl.GuildEnvCommentGuildRaid = Looking forward to the next guild raid!|Hope we get some good loot in the next raid.|Who's ready for raid night?

# OllamaBotControl.GuildEnvCommentGuildEndgame
#     Description: Templates for commenting on endgame content. Pipe-separated (|) list.
#     Example: "Endgame content is tough but fun."
#     Default: (empty - no endgame comments)
OllamaBotControl.GuildEnvCommentGuildEndgame = Endgame content is tough but fun.|We need more people for endgame runs.|Anyone up for some endgame challenges?

# OllamaBotControl.GuildEnvCommentGuildStrategy
#     Description: Templates for discussing guild strategies. Pipe-separated (|) list.
#     Example: "We should try a new strategy for the next boss."
#     Default: (empty - no strategy comments)
OllamaBotControl.GuildEnvCommentGuildStrategy = We should try a new strategy for the next boss.|Strategy is key to our success.|Let's discuss tactics for the next fight.

# OllamaBotControl.GuildEnvCommentGuildGroup
#     Description: Templates for group/quest/grind activity. Pipe-separated (|) list.
#     Example: "Anyone want to group up for quests?"
#     Default: (empty - no group comments)
OllamaBotControl.GuildEnvCommentGuildGroup = Anyone want to group up for quests?|Grinding with guildies is more fun.|Let's form a group for dailies.

# OllamaBotControl.GuildEnvCommentGuildPvP
#     Description: Templates for guild PvP activity. Pipe-separated (|) list.
#     Example: "Who's up for some PvP tonight?"
#     Default: (empty - no PvP comments)
OllamaBotControl.GuildEnvCommentGuildPvP = Who's up for some PvP tonight?|PvP with the guild is always intense.|Let's queue for some battlegrounds together.

# OllamaBotControl.GuildEnvCommentGuildCommunity
#     Description: Templates for community/social comments. Pipe-separated (|) list.
#     Example: "Guild community is the best part of the game."
#     Default: (empty - no community comments)
OllamaBotControl.GuildEnvCommentGuildCommunity = Guild community is the best part of the game.|Love hanging out with everyone here.|Our guild socials are always a blast.

# --------------------------------------------
# GUILD EVENT TYPES
# --------------------------------------------

# OllamaBotControl.GuildEventTypeEpicGear
#     Description: Event type for guild epic gear acquisition announcements.
#                  Creates excitement and congratulations for rare loot.
#     Example:     "Grats on the epic loot!"
#     Default:     guild member got epic gear
OllamaBotControl.GuildEventTypeEpicGear = guild member got epic gear
OllamaBotControl.GuildEventTypeEpicGear_Chance = 95

# OllamaBotControl.GuildEventTypeRareGear
#     Description: Event type for guild rare gear acquisition announcements.
#                  Triggered when a guild member obtains rare (blue) quality weapons or armor.
#                  Only announces equipment, not consumables or trade goods.
#     Example:     "Nice blue gear upgrade!"
#     Default:     guild member got rare gear
OllamaBotControl.GuildEventTypeRareGear = guild member got rare gear
OllamaBotControl.GuildEventTypeRareGear_Chance = 65

# OllamaBotControl.GuildEventTypeGuildJoin
#     Description: Event type for guild member join announcements.
#                  Triggered when a new player joins the guild.
#                  Welcomes new members to the guild community.
#     Example:     "Welcome to the guild!"
#     Default:     member joined guild
OllamaBotControl.GuildEventTypeGuildJoin = member joined guild
OllamaBotControl.GuildEventTypeGuildJoin_Chance = 12

# OllamaBotControl.GuildEventTypeGuildLogin
#     Description: Event type for guild member login announcements.
#                  Triggered when a non-bot guild member logs in.
#                  Welcomes returning members to the guild.
#     Example:     "{actor_name} has logged in to the guild!"
#     Default:     member logged in
OllamaBotControl.GuildEventTypeGuildLogin = member logged in
OllamaBotControl.GuildEventTypeGuildLogin_Chance = 85

# OllamaBotControl.GuildEventTypeGuildLeave
#     Description: Event type for guild member leave announcements.
#                  Triggered when a player leaves the guild.
#                  Acknowledges departing members.
#     Example:     "Sad to see them go."
#     Default:     member left guild
OllamaBotControl.GuildEventTypeGuildLeave = member left guild
OllamaBotControl.GuildEventTypeGuildLeave_Chance = 85

# OllamaBotControl.GuildEventTypeGuildPromotion
#     Description: Event type for guild member promotion announcements.
#                  Triggered when a guild member gets promoted to a higher rank.
#                  Celebrates advancement within the guild hierarchy.
#     Example:     "Congrats on the promotion!"
#     Default:     member got promoted
OllamaBotControl.GuildEventTypeGuildPromotion = member got promoted
OllamaBotControl.GuildEventTypeGuildPromotion_Chance = 25

# OllamaBotControl.GuildEventTypeGuildDemotion
#     Description: Event type for guild member demotion announcements.
#                  Triggered when a guild member gets demoted to a lower rank.
#                  Handles rank changes sensitively.
#     Example:     "Rank changes happen."
#     Default:     member got demoted
OllamaBotControl.GuildEventTypeGuildDemotion = member got demoted
OllamaBotControl.GuildEventTypeGuildDemotion_Chance = 5

# OllamaBotControl.GuildEventTypeGuildAchievement
#     Description: Event type for guild member achievement announcements.
#                  Triggered when a real (non-bot) guild member earns an achievement.
#                  Celebrates player accomplishments in the guild.
#     Example:     "{actor_name} just earned an achievement!"
#     Default:     member earned achievement
OllamaBotControl.GuildEventTypeGuildAchievement = member earned achievement
OllamaBotControl.GuildEventTypeGuildAchievement_Chance = 85

# OllamaBotControl.GuildEventTypeLevelUp
#     Description: Event type for guild member level up announcements.
#                  Triggered when a guild member levels up.
#                  Celebrates player progression in the guild.
#     Example:     "Grats on the level up!"
#     Default:     member leveled up
OllamaBotControl.GuildEventTypeLevelUp = member leveled up
OllamaBotControl.GuildEventTypeLevelUp_Chance = 95

# OllamaBotControl.GuildEventTypeDungeonComplete
#     Description: Event type for guild dungeon completion announcements.
#                  Triggered when a guild group completes a dungeon.
#                  Recognizes group achievements in PvE content.
#     Example:     "Dungeon run complete!"
#     Default:     guild group completed a dungeon
OllamaBotControl.GuildEventTypeDungeonComplete = guild group completed a dungeon
OllamaBotControl.GuildEventTypeDungeonComplete_Chance = 85

# --------------------------------------------
# RAG (Retrieval-Augmented Generation) SYSTEM
# --------------------------------------------

# OllamaBotControl.EnableRAG
#     Description: Enable or disable the RAG (Retrieval-Augmented Generation) feature.
#                  When enabled, the bot will analyze player messages and retrieve relevant information
#                  from JSON knowledge base files to provide more accurate and detailed responses.
#     Default:     0 (false)
OllamaBotControl.EnableRAG = 0



# OllamaBotControl.RAGDataPath
#     Description: Path to the directory containing RAG JSON data files.
#                  This should be a relative path from the server's working directory.
#                  For AzerothCore installations, this is typically ../../../modules/mod-ollama-chat/data/rag/
#                  The system will load all .json files from this directory.
#     Default:     ../../../modules/mod-ollama-chat/data/rag/
OllamaBotControl.RAGDataPath = ../../../modules/mod-ollama-chat/data/rag/



# OllamaBotControl.RAGMaxRetrievedItems
#     Description: Maximum number of relevant information items to retrieve and include in the prompt.
#                  Higher values provide more context but may exceed token limits.
#     Default:     3
OllamaBotControl.RAGMaxRetrievedItems = 3



# OllamaBotControl.RAGSimilarityThreshold
#     Description: Minimum similarity score (0.0-1.0) required for information to be considered relevant.
#                  Lower values will include more information but may be less accurate.
#                  Higher values will be more precise but may miss relevant information.
#                  Recommended range: 0.2-0.4 for good balance of relevance and coverage.
#     Default:     0.3
OllamaBotControl.RAGSimilarityThreshold = 0.3



# OllamaBotControl.RAGPromptTemplate
#     Description: Template for including RAG information in bot prompts.
#     Placeholders (named): {rag_info}
OllamaBotControl.RAGPromptTemplate = "RELEVANT INFORMATION:\n{rag_info}\nUse this information to provide accurate and detailed responses when applicable."

#
###############################################################################
# LLM BOT ACTION CONTROL (mod-ollama-bot-control)
###############################################################################
#
# OllamaBotControl.AllowedActions
#     Description: Comma-separated allow-list of LLM action command types an
#                  opted-in bot may execute. Any command type not in this list
#                  is rejected silently. Empty = allow the full v1 set.
#     v1 actions:  attack, follow, come, stay, moveto, emote
#     Default:     "attack,follow,come,stay,moveto,emote"
OllamaBotControl.AllowedActions = "attack,follow,come,stay,moveto,emote"
#
# OllamaBotControl.ControlDurationSeconds
#     Description: How long (seconds) an opted-in bot stays under external control
#                  after a movement/combat command (attack/follow/moveto). The lease
#                  is renewed on every command; once it lapses with no further
#                  interaction the bot returns to its own autonomous behaviour (it is
#                  never left frozen). Requires the mod-playerbots external-control
#                  patch (xthree/mod-playerbots branch external-control).
#     Default:     180
OllamaBotControl.ControlDurationSeconds = 180
#
# Opt-in is per-bot and runtime-controlled (not a config key):
#     .ollama optin <botName>     - enable LLM action control for a bot
#     .ollama optout <botName>    - disable it
#     .ollama optstatus <botName> - show current state
# (Opt-in state is in-memory for now and resets on worldserver restart.)